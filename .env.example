# Next.js 앱
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/burn_emotion
NEXT_PUBLIC_WS_URL=wss://ws.burn-emotion.net
NEXT_PUBLIC_SITE_URL=https://burn-emotion.net

# WS 가 막힌 환경(회사 프록시 등)용 same-origin SSE+POST 폴백.
# Next /api/realtime/* 가 릴레이로 프록시할 주소. 미설정 시 NEXT_PUBLIC_WS_URL 에서 유도(wss→https).
# 같은 네트워크면 내부 주소로 두는 게 효율적.
REALTIME_HTTP_ORIGIN=http://realtime:8080
# 릴레이의 SSE/POST 를 Next 프록시만 쓰게 잠그는 공유 시크릿(선택). 릴레이·Next 양쪽에 같은 값.
REALTIME_PROXY_SECRET=

# WS 서버 (realtime-server)
PORT=8080
ALLOWED_ORIGIN=https://burn-emotion.net
